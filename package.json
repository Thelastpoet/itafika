{
  "name": "itafika",
  "version": "0.1.0",
  "private": true,
  "description": "A delivery orchestration API/control plane for ecommerce checkout in Kenya",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "data:validate": "pnpm --filter @itafika/worker data:validate",
    "gen:types": "pnpm --filter @itafika/core gen:types",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm --filter @itafika/worker dev"
  }
}
